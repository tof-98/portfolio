---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Toufic Hanna — Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta property="og:title" content="Toufic Hanna — Application Programmer" />
    <meta property="og:description" content="Application programmer specialising in Spring Boot, Java, REST APIs, and web security." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=JetBrains+Mono:wght@400;500&family=Outfit:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav>
      <div class="nav-logo">Toufic<span>.</span></div>
      <ul class="nav-links">
        <li><a href="#about">About</a></li>
        <li><a href="#projects">Projects</a></li>
        <li><a href="#experience">Experience</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
      <a href="#contact" class="nav-cta">Hire me →</a>
    </nav>

    <slot />

    <footer>
      <div class="footer-copy">© 2026 Toufic Hanna. Built with care.</div>
      <div class="footer-dot"></div>
      <div class="footer-copy">Hall in Tirol, AT · Open to Remote</div>
    </footer>

    <script>
      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("visible");
              obs.unobserve(e.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll(".fade-up:not(.visible)").forEach((el) => obs.observe(el));
    </script>
  </body>
</html>
